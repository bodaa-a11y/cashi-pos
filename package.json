{
  "name": "cashi",
  "productName": "كاشي - نظام الكاشير المتكامل",
  "private": true,
  "version": "1.0.0",
  "description": "نظام كاشي المتكامل لنقطة البيع - برنامج سطح مكتب ويندوز",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build",
    "build:server": "esbuild server.ts --bundle --platform=node --format=esm --packages=external --sourcemap --outfile=dist-electron/server.js",
    "build:electron": "esbuild electron/main.ts electron/printer.ts --bundle --platform=node --format=esm --packages=external --sourcemap --outdir=dist-electron && esbuild electron/preload.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outdir=dist-electron",
    "electron:dev": "npm run build && npm run build:server && npm run build:electron && electron .",
    "electron:build": "npm run build && npm run build:server && npm run build:electron && electron-builder --win",
    "electron:pack": "npm run build && npm run build:server && npm run build:electron && electron-builder --win --dir",
    "start": "electron .",
    "clean": "rm -rf dist dist-electron db.json",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^4.21.2",
    "mongodb": "^7.4.0",
    "node-thermal-printer": "^4.4.0",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "electron": "^35.7.5",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.25.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "recharts": "^3.9.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  },
  "build": {
    "extends": "./electron-builder.config.js"
  }
}
